    "plaid": "^41.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-plaid-link": "^4.1.1",
    "recharts": "^3.8.0",
    "resend": "^6.9.3",
