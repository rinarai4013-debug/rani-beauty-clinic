{
  "redirects": [
    {
      "source": "/:path((?!api).*)",
      "has": [
        {
          "type": "host",
          "value": "ranibeautyclinic.com"
        }
      ],
      "destination": "https://www.ranibeautyclinic.com/:path",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-briefing",
      "schedule": "0 14 * * *"
    }
  ]
}
