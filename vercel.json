{
  "redirects": [
    {
      "source": "/:path((?!api).*)",
      "has": [
        {
          "type": "host",
          "value": "ranibeautyclinic.com"
        }
      ],
      "destination": "https://www.ranibeautyclinic.com/:path",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "offers.ranibeautyclinic.com"
        }
      ],
      "destination": "https://www.ranibeautyclinic.com/pricing",
      "permanent": true
    }
  ],
  "crons": []
}
