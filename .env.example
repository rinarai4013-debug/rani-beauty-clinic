# ===================================================================
# Rani Beauty Clinic — Environment Variables
# Copy this file to .env.local and fill in values
# ===================================================================

# -- Core (Required) -----------------------------------------------

AIRTABLE_PAT=pat_xxxxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=app1SwhSfwe8GKUg4
# Generate a strong random secret: openssl rand -hex 32
DASHBOARD_JWT_SECRET=
# JSON object: {"user@email.com": "hashed_password"}
DASHBOARD_USERS=

# -- Auth -----------------------------------------------------------

# Separate JWT secret for patient portal sessions — openssl rand -hex 32
PATIENT_JWT_SECRET=
# Secret to authenticate cron job requests — openssl rand -hex 32
CRON_SECRET=

# -- URLs -----------------------------------------------------------

NEXT_PUBLIC_BASE_URL=https://www.ranibeautyclinic.com
NEXT_PUBLIC_SITE_URL=https://ranibeautyclinic.com

# -- AI / LLM ------------------------------------------------------

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# Set to "true" to bypass AI calls with mock data during development
# USE_MOCK_AI=true

# -- Email ----------------------------------------------------------

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
CONTACT_EMAIL=info@ranibeautyclinic.com
FROM_EMAIL=Rani Beauty Clinic <noreply@ranibeautyclinic.com>

# -- SMS (Twilio — used in daily-briefing cron) ---------------------

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
OWNER_PHONE=

# -- Payments (Stripe) ---------------------------------------------

STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# -- Payments (Cherry financing) ------------------------------------

CHERRY_API_KEY=
CHERRY_WEBHOOK_SECRET=

# -- Payments (Square POS + Memberships) ----------------------------

SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
# Membership plan IDs (optional — defaults to plan_<tier>_<period>)
# SQUARE_PLAN_HALO_MONTHLY=
# SQUARE_PLAN_HALO_ANNUAL=
# SQUARE_PLAN_GLOW_MONTHLY=
# SQUARE_PLAN_GLOW_ANNUAL=
# SQUARE_PLAN_ELITE_MONTHLY=
# SQUARE_PLAN_ELITE_ANNUAL=

# -- Booking (Mangomint) -------------------------------------------

MANGOMINT_WEBHOOK_SECRET=

# -- Automation (n8n) -----------------------------------------------

N8N_WEBHOOK_URL=https://ranibeautyclinic.app.n8n.cloud/webhook/XXXXX
# n8n API key for direct API calls (template routes)
N8N_API_KEY=
# Optional webhook timeout override in milliseconds
# WEBHOOK_TIMEOUT_MS=5000

# -- Banking (Plaid) ------------------------------------------------

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# -- Vector DB / Embeddings -----------------------------------------

PINECONE_API_KEY=
# Use Voyage AI for embeddings (Anthropic partner) — dash.voyageai.com
VOYAGE_API_KEY=
# Or use OpenAI embeddings — platform.openai.com
OPENAI_API_KEY=

# -- Photo Simulation (Replicate) -----------------------------------

REPLICATE_API_TOKEN=

# -- Voice AI (Vapi) ------------------------------------------------

VAPI_API_KEY=
VAPI_ASSISTANT_ID=

# -- Meta Ads -------------------------------------------------------

META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# -- Meta Conversions API (CAPI webhook) ----------------------------

META_CAPI_ACCESS_TOKEN=
META_CAPI_WEBHOOK_SECRET=
NEXT_PUBLIC_META_PIXEL_ID=769852657929598

# -- QuickBooks Online ----------------------------------------------

QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=https://ranibeautyclinic.com/api/integrations/quickbooks/auth?action=callback
QBO_REALM_ID=
QBO_ENVIRONMENT=sandbox
# Optional: stored tokens (auto-managed after OAuth flow)
QBO_ACCESS_TOKEN=
QBO_REFRESH_TOKEN=
# Optional: webhook signature verification
QBO_WEBHOOK_VERIFIER_TOKEN=

# -- SaaS Multi-Tenant (RaniOS) ------------------------------------

RANIOS_MASTER_PAT=
RANIOS_MASTER_BASE_ID=

# -- SaaS Billing (Stripe Price IDs) --------------------------------

STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# -- Sentry Error Tracking -----------------------------------------

NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
