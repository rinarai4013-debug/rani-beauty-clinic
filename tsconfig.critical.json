{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo.critical"
  },
  "include": [
    "next-env.d.ts",
    "src/types/**/*.ts",

    "src/app/api/contact/route.ts",
    "src/app/api/photo/upload/route.ts",
    "src/app/api/skin-analysis/route.ts",
    "src/app/api/patient/**/*.ts",
    "src/app/api/ai/**/*.ts",
    "src/app/api/booking/**/*.ts",
    "src/app/api/consultation/**/*.ts",
    "src/app/api/webhooks/**/*.ts",
    "src/app/api/health/route.ts",
    "src/app/api/plan/**/*.ts",
    "src/app/api/templates/**/*.ts",
    "src/app/api/indexnow/route.ts",

    "src/lib/auth/**/*.ts",
    "src/lib/patient-auth/**/*.ts",
    "src/lib/airtable/client.ts",
    "src/lib/airtable/tables.ts",
    "src/lib/airtable/sanitize.ts",
    "src/lib/airtable/schemas.ts",
    "src/lib/airtable/cache.ts",
    "src/lib/airtable/batch.ts",
    "src/lib/airtable/circuit-breaker.ts",
    "src/lib/airtable/write-queue.ts",
    "src/lib/rate-limit.ts",
    "src/lib/cache/index.ts",
    "src/lib/ai/**/*.ts",
    "src/lib/plan-builder/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "remotion",
    "scripts",
    "src/middleware.ts",
    "src/lib/saas",
    "src/lib/sdk",
    "src/lib/tenant",
    "src/lib/integrations/quickbooks",
    "src/app/api/tenant",
    "src/hooks/useTenantDashboard.ts",
    "src/components/tenant",
    "src/stories",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.stories.ts",
    "**/*.stories.tsx",
    "**/*.bak",
    "**/*.full"
  ]
}
