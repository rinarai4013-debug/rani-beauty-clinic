{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "tsBuildInfoFile": "./.next/cache/tsconfig.critical.tsbuildinfo",
    "plugins": [],
    "types": ["node"],
    "paths": {
      "@/lib/sentry-utils": ["./types/critical-stubs/sentry-utils.d.ts"],
      "@sentry/nextjs": ["./types/critical-stubs/sentry-nextjs.d.ts"],
      "@/lib/booking/availability": ["./types/critical-stubs/booking-availability.d.ts"],
      "@/lib/booking/data": ["./types/critical-stubs/booking-data.d.ts"],
      "@/lib/booking/calendar": ["./types/critical-stubs/booking-calendar.d.ts"],
      "@/lib/booking/intake": ["./types/critical-stubs/booking-intake.d.ts"],
      "@/lib/booking/reminders": ["./types/critical-stubs/booking-reminders.d.ts"],
      "date-fns": ["./types/critical-stubs/date-fns.d.ts"],
      "stripe": ["./types/critical-stubs/stripe.d.ts"],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "middleware.ts",
    "src/app/api/health/route.ts",
    "src/app/api/contact/route.ts",
    "src/app/api/photo/upload/route.ts",
    "src/app/api/skin-analysis/route.ts",
    "src/app/api/templates/pdf/route.ts",
    "src/app/api/patient/auth/magic-link/route.ts",
    "src/app/api/patient/auth/me/route.ts",
    "src/app/api/patient/auth/verify/route.ts",
    "src/app/api/patient/profile/route.ts",
    "src/app/api/patient/plan/route.ts",
    "src/app/api/plan/[id]/route.ts",
    "src/app/api/plan/[id]/track/route.ts",
    "src/app/api/webhooks/cherry/route.ts",
    "src/app/api/webhooks/mangomint/route.ts",
    "src/app/api/webhooks/stripe/route.ts",
    "src/app/api/booking/availability/route.ts",
    "src/app/api/booking/book/route.ts",
    "src/app/api/booking/calendar/route.ts",
    "src/app/api/booking/intake/route.ts",
    "src/app/api/booking/reminders/route.ts",
    "src/app/api/booking/waitlist/route.ts",
    "src/app/api/consultation/submit/route.ts",
    "src/app/api/dashboard/auth/login/route.ts",
    "src/app/api/dashboard/auth/logout/route.ts",
    "src/app/api/dashboard/auth/me/route.ts",
    "src/app/api/dashboard/revenue-optimizer/route.ts",
    "src/app/plan/[id]/TreatmentPlanClient.tsx"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "scripts",
    "remotion",
    "src/middleware.ts",
    "src/app/(saas)/**",
    "src/lib/saas/**",
    "src/lib/tenant/**",
    "src/lib/sdk/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.stories.tsx",
    "**/*.bak",
    "**/*.full",
    "**/* 2.ts",
    "**/* 2.tsx",
    "**/* 3.ts",
    "**/* 3.tsx"
  ]
}
